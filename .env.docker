# SpellWise Environment Configuration for Multi-App Hosting
# Production URL: https://demo.colaps.team/spellwise

# Node environment
NODE_ENV=production

# MongoDB
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme123!
MONGO_PORT=27017

# Server (internal, not exposed)
PORT=4000
BASE_PATH=/spellwise

# Client (internal, accessed through reverse proxy)
CLIENT_PORT=3000

# Application Base Path (for nginx routing)
APP_BASE_PATH=/spellwise

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-this-in-production-now
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-this-in-production-now

# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# Application
LOG_LEVEL=info

# Multi-App Configuration
# Served at: https://demo.colaps.team/spellwise
VITE_BASE_PATH=/spellwise/
VITE_API_URL=https://demo.colaps.team/spellwise/api

