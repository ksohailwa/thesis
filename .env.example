# ============================================
# SpellWise Environment Configuration Example
# ============================================
# Copy this file to .env and fill in your values

# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=your-secure-password
MONGO_PORT=27017

# Server Configuration
NODE_ENV=production
PORT=4000
APP_PORT=4000
CORS_ORIGIN=http://localhost:3000/SpellWise

# JWT Secrets (generate new random values in production)
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

# Internal Configuration
INTERNAL_JOB_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX

# OpenAI Configuration
OPENAI_API_KEY=sk-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# TTS Configuration
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
ELEVENLABS_API_KEY=YOUR_KEY_HERE
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=YOUR_VOICE_ID_HERE

# Client Configuration
CLIENT_PORT=3000
VITE_API_BASE_URL=http://localhost:4000
VITE_BASE_PATH=/spellwise/
